<section id="booking" class="py-5" style=" position: relative; z-index: 10; border-bottom: 1px solid rgba(156, 132, 94, 0.15);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="card booking-card border-0 shadow-lg" style="border-radius: 1.5rem; overflow: hidden;">
                    <div class="card-body p-4 p-md-5 bg-white">
                        <h3 class="text-center fw-bold mb-5" style="color: var(--primary-color); font-size: 2.5rem;">Empecemos a planear sus vacaciones</h3>
                        <form id="realBookingForm" class="booking-form">
                            <input type="hidden" name="servicio" value="Hospedaje" />

                            <!-- Sección 1: Fechas -->
                            <div class="row mb-4 pb-2 border-bottom">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label for="fecha-entrada" class="form-label fw-semibold" style="color: var(--secondary-color);">1. Fecha de entrada</label>
                                    <input type="date" class="form-control rounded-pill px-4 py-2 bg-light border-0" id="fecha-entrada" name="fecha_entrada" required />
                                </div>
                                <div class="col-md-6">
                                    <label for="fecha-salida" class="form-label fw-semibold" style="color: var(--secondary-color);">Fecha de salida</label>
                                    <input type="date" class="form-control rounded-pill px-4 py-2 bg-light border-0" id="fecha-salida" name="fecha_salida" required />
                                </div>
                            </div>

                            <!-- Sección 2: Datos de tus perros -->
                            <div class="row mb-4 pb-2 border-bottom">
                                <div class="col-12 mb-3">
                                    <label for="cantidad-perros" class="form-label fw-semibold" style="color: var(--secondary-color);">2. ¿Cuántos perros quieres hospedar?</label>
                                    <select class="form-select rounded-pill px-4 py-2 bg-light border-0" id="cantidad-perros" name="cantidad_perros" required style="height: 50px;">
                                        <option value="" disabled selected>Selecciona cantidad</option>
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4+">4 o más</option>
                                    </select>
                                </div>
                                <div class="col-12 mb-3">
                                    <label for="detalles-perros" class="form-label fw-semibold" style="color: var(--secondary-color);">Cuéntanos sobre tu(s) perro(s): nombre, raza, tamaño. Tenemos muchas ganas de irlo(s) conociendo</label>
                                    <textarea class="form-control rounded-4 px-4 py-2 bg-light border-0" id="detalles-perros" name="detalles_perros" rows="2" placeholder="Ej. Toby (Mestizo, Mediano), Luna (Chihuahua, Chica)..." required style="min-height: 50px;"></textarea>
                                </div>
                            </div>

                            <!-- Sección 3: Datos de Contacto -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold mb-3" style="color: var(--secondary-color);">3. Tus datos de contacto</label>
                                <div class="row g-3">
                                    <div class="col-md-12 mb-2">
                                        <input type="text" class="form-control rounded-pill px-4 py-3 bg-light border-0" placeholder="Nombre completo" name="nombre" required />
                                    </div>
                                    <div class="col-md-6">
                                        <input type="tel" id="telefono" class="form-control rounded-pill pe-4 py-3 bg-light border-0" placeholder="Celular / WhatsApp" name="telefono" required />
                                    </div>
                                    <div class="col-md-6">
                                        <input type="email" class="form-control rounded-pill px-4 py-3 bg-light border-0" placeholder="Correo electrónico" name="correo" required />
                                    </div>
                                </div>
                            </div>

                            <!-- Botón de acción -->
                            <div class="text-center mt-5">
                                <div class="form-check form-switch d-inline-flex align-items-center mb-3 text-start">
                                    <input class="form-check-input custom-switch" type="checkbox" role="switch" id="experienciaCompleta" name="experiencia_completa" checked style="cursor: pointer; width: 2.2em; height: 1.1em;" />
                                    <label class="form-check-label fs-6 fw-semibold ms-2" for="experienciaCompleta" style="color: var(--primary-color); cursor: pointer;">Me interesa recibir información de interés de Bark & Co. Dog Wellness Club.</label>
                                </div>
                                <button type="submit" class="btn btn-accent-green btn-lg px-5 py-3 w-100 fs-5 fw-bold shadow-sm">Quiero reservar</button>
                                <p class="text-center text-muted small mt-3 mb-0">Te contactaremos en menos de 24 horas para validar disponibilidad y coordinar todos los detalles de acuerdo a tus necesidades.</p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Carga de intl-tel-input CSS/JS y SweetAlert2 desde CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.3.4/build/css/intlTelInput.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/intl-tel-input@24.3.4/build/js/intlTelInput.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('realBookingForm');
        const inputEntrada = document.getElementById('fecha-entrada');
        const inputSalida = document.getElementById('fecha-salida');
        const inputTelefono = document.getElementById('telefono');

        // Función para mostrar alertas elegantes con SweetAlert2
        function mostrarAlerta(titulo, mensaje, tipo = 'warning', textoBoton = 'Entendido') {
            if (window.Swal) {
                window.Swal.fire({
                    title: titulo,
                    text: mensaje,
                    icon: tipo,
                    confirmButtonText: textoBoton,
                    confirmButtonColor: '#4D967C', // Color de marca accent-green
                    customClass: {
                        popup: 'custom-swal-popup',
                        confirmButton: 'custom-swal-btn'
                    }
                });
            } else {
                alert(mensaje);
            }
        }

        // Inicializar intl-tel-input
        let iti;
        if (inputTelefono && window.intlTelInput) {
            iti = window.intlTelInput(inputTelefono, {
                initialCountry: "mx",
                onlyCountries: ["mx"],
                allowDropdown: false,
                placeholderNumberType: "MOBILE",
                containerClass: "w-100",
                utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@24.3.4/build/js/utils.js",
            });
        }

        // Configuración dinámica de mínimos de fecha para UX
        if (inputEntrada && inputSalida) {
            const today = new Date().toISOString().split('T')[0];
            inputEntrada.min = today;

            inputEntrada.addEventListener('change', function () {
                if (inputEntrada.value) {
                    // La fecha de salida debe ser al menos un día después de la entrada
                    const entryDate = new Date(inputEntrada.value + 'T00:00:00');
                    entryDate.setDate(entryDate.getDate() + 1);
                    const minSalida = entryDate.toISOString().split('T')[0];
                    inputSalida.min = minSalida;

                    // Si la fecha de salida ya seleccionada es menor o igual, la actualizamos
                    if (inputSalida.value && inputSalida.value < minSalida) {
                        inputSalida.value = minSalida;
                    }
                }
            });
        }

        if (form) {
            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());

                // 1. Validación de Fechas
                if (!data.fecha_entrada || !data.fecha_salida) {
                    mostrarAlerta('Fechas incompletas', 'Por favor, indica las fechas de entrada y salida para apartar tu lugar.');
                    return;
                }

                const fechaEntrada = new Date(data.fecha_entrada + 'T00:00:00');
                const fechaSalida = new Date(data.fecha_salida + 'T00:00:00');

                if (fechaSalida <= fechaEntrada) {
                    mostrarAlerta('Fecha inválida', 'La fecha de salida debe ser mayor a la fecha de entrada.');
                    return;
                }

                // 2. Validación de Celular / WhatsApp con intl-tel-input
                if (iti) {
                    if (!iti.isValidNumber()) {
                        mostrarAlerta('Teléfono inválido', 'Por favor, ingresa un número de celular o WhatsApp válido.');
                        return;
                    }
                    // Estandarizar el teléfono al formato internacional (E.164)
                    data.telefono = iti.getNumber();
                } else {
                    const telefonoLimpio = data.telefono.replace(/\D/g, '');
                    if (telefonoLimpio.length < 10) {
                        mostrarAlerta('Teléfono inválido', 'Por favor, ingresa un número de celular o WhatsApp válido de al menos 10 dígitos.');
                        return;
                    }
                }

                // 3. Validación de Correo Electrónico
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRegex.test(data.correo)) {
                    mostrarAlerta('Correo inválido', 'Por favor, ingresa un correo electrónico válido.');
                    return;
                }

                data.origen = window.location.origin + window.location.pathname;

                // Capturar y enviar parámetros UTM
                const urlParams = new URLSearchParams(window.location.search);
                const utms = ['utm_id', 'utm_campaign', 'utm_source', 'utm_medium', 'utm_content', 'utm_term'];
                utms.forEach(utm => {
                    data[utm] = urlParams.get(utm) || '';
                });

                const btn = form.querySelector('button[type="submit"]');
                const originalText = btn ? btn.textContent : 'Quiero reservar';

                if (btn) {
                    btn.textContent = 'Enviando...';
                    btn.disabled = true;
                }

                try {
                    const response = await fetch('https://n8n.ongoing.mx/webhook/2dd3eed3-0f4f-41a3-a861-66d2e8265e97', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            barkco: 'Huo0lpaw.',
                        },
                        body: JSON.stringify(data),
                    });

                    if (response.ok) {
                        mostrarAlerta('¡Solicitud enviada!', 'Te contactaremos en menos de 24 horas para validar disponibilidad y coordinar todos los detalles de acuerdo a tus necesidades.', 'success', 'Excelente');
                        form.reset();
                        if (iti) {
                            iti.setNumber('');
                        }
                        // Restablecer los mínimos de fecha
                        if (inputEntrada && inputSalida) {
                            const today = new Date().toISOString().split('T')[0];
                            inputEntrada.min = today;
                            inputSalida.min = '';
                        }
                    } else {
                        console.error('Error de respuesta del servidor:', response.status);
                        mostrarAlerta('Error de envío', 'Lo sentimos, tuvimos un problema al procesar tu solicitud. Por favor, intenta de nuevo más tarde.', 'error');
                    }
                } catch (error) {
                    console.error('Error de conexión en fetch:', error);
                    mostrarAlerta('Problema de conexión', 'No pudimos conectar con el servidor. Por favor, verifica tu conexión a internet o intenta de nuevo en unos momentos.', 'error');
                } finally {
                    if (btn) {
                        btn.textContent = originalText;
                        btn.disabled = false;
                    }
                }
            });
        }
    });
</script>

<style>
    .custom-switch:checked {
        background-color: var(--accent-green) !important;
        border-color: var(--accent-green) !important;
    }

    /* Desactivar efecto zoom/elevación en el formulario */
    .booking-card,
    .booking-card:hover {
        transform: none !important;
        transition: none !important;
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.175) !important; /* Conservar la sombra Bootstrap shadow-lg estática */
    }

    /* Ajustes para intl-tel-input con Bootstrap 5 */
    .iti {
        width: 100%;
        display: block;
    }
    .iti__country-list {
        border-radius: 1rem;
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1);
    }

    /* SweetAlert2 Custom Styling */
    .custom-swal-popup {
        font-family: var(--font-primary, 'Plus Jakarta Sans', sans-serif) !important;
        border-radius: 1.5rem !important;
        padding: 2.5rem 1.5rem !important;
        background-color: var(--white, #FFFFFF) !important;
    }
    .custom-swal-btn {
        border-radius: 50px !important;
        padding: 0.75rem 2.5rem !important;
        font-weight: 600 !important;
        font-size: 1rem !important;
        transition: all 0.2s ease-in-out !important;
    }
    .custom-swal-btn:hover {
        opacity: 0.9 !important;
    }
</style>
