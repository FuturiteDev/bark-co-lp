            <div class="col-md-12 text-center text-white">
                <img src="/reserva/assets/img/logo_BarknCo.png" class="logo-gracias" alt="Bark & Co Logo">
                <h5 class="mt-5 fs-2 font-decorative" style="color: var(--secondary-color);">
