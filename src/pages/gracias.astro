            color: var(--primary-color, #1a1a1a);
            padding: 12px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: bold;
            display: inline-block;
            transition: all 0.3s;
        }
        .btn-cta.white:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }
